# Copie este arquivo para ".env" e cole suas chaves reais.
# NUNCA coloque as chaves reais neste arquivo de exemplo nem no código-fonte.

# Mercado Pago
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
MP_PUBLIC_KEY=SUA_PUBLIC_KEY_AQUI

# Discord - URL do Webhook do canal de novidades
# Como pegar: no Discord, Configurações do Canal > Integrações > Webhooks > Novo Webhook > Copiar URL do Webhook
DISCORD_WEBHOOK_URL=SUA_URL_DE_WEBHOOK_AQUI
